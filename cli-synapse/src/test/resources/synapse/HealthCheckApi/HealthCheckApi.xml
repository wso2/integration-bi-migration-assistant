<?xml version="1.0" encoding="UTF-8"?>
<api xmlns="http://ws.apache.org/ns/synapse"
     name="HealthCheckApi"
     context="/healthcheck">
    <resource methods="GET" uri-template="/status">
        <inSequence>
            <log level="custom">
                <property name="message" value="Health check requested"/>
            </log>
            <payloadFactory media-type="json">
                <format>{"status":"UP"}</format>
                <args/>
            </payloadFactory>
            <respond/>
        </inSequence>
        <faultSequence/>
    </resource>
</api>
